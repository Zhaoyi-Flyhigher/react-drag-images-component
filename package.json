{
  "name": "react-drag-images-component",
  "version": "0.0.11",
  "description": "react 图片拖拽组件",
  "type": "module",
  "main": "./dist/index.mini.cjs",
  "module": "./dist/index.mini.esm.js",
  "types": "./dist/types/index.d.ts",
  "typesVersions": {
    "module": {
      "*": ["dist/types/*.d.ts"]
    },
    "commonjs": {
      "*": ["dist/types/*.cjs.d.ts"]
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "rsbuild dev",
    "build:types": "tsc --project tsconfig.json --declaration --emitDeclarationOnly",
    "build": "rollup -c --bundleConfigAsCjs",
    "release": "bumpp && npm publish"
  },
  "keywords": [
    "react",
    "react-drag",
    "react-drag-img",
    "react-drag-imges",
    "react-component",
    "react-drag-component"
  ],
  "repository": "https://github.com/Zhaoyi-Flyhigher/react-drag-images-component",
  "author": "zhaoyi <banbaoyan_zy@163.com>",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@rollup/plugin-url": "^8.0.2",
    "@rsbuild/core": "^1.0.19",
    "@rsbuild/plugin-react": "^1.0.6",
    "@rsbuild/plugin-sass": "^1.1.0",
    "@rsbuild/plugin-type-check": "^1.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "bumpp": "^9.8.0",
    "rollup": "^4.24.4",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-sass": "^1.14.0",
    "sass": "^1.80.6",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "rollup-plugin-postcss": "^4.0.2",
    "uuid": "^11.0.2"
  },
  "peerDependencies": {
    "lodash-es": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
